// Firebase 콘솔 → Storage → 규칙 탭에 아래 내용을 붙여넣으세요

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // 아바타 사진: 본인만 업로드, 로그인 사용자는 모두 열람
    match /avatars/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // 게시글 사진: 로그인 사용자 모두 업로드/열람
    match /posts/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.size < 5 * 1024 * 1024; // 5MB 제한
    }

    // 미션 인증샷
    match /missions/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId && request.resource.size < 10 * 1024 * 1024; // 10MB 제한
    }
  }
}
