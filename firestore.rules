rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // 프로필: 로그인하면 읽기, 본인만 쓰기 / 삭제는 누구나 허용(관리자 삭제용)
    match /profiles/{userId} {
      allow read: if isLoggedIn();
      allow create, update: if isOwner(userId);
      allow delete: if isLoggedIn(); // 관리자가 삭제할 수 있도록
    }

    // 관리자 오버라이드: 로그인한 사용자 모두 쓰기 가능 (관리자 수정용)
    match /adminOverrides/{userId} {
      allow read, write: if isLoggedIn();
    }

    // 티미팅: 로그인하면 읽기/쓰기
    match /meetings/{meetingId} {
      allow read, write: if isLoggedIn();
    }

    // 게시글
    match /posts/{postId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isLoggedIn();
      allow delete: if isLoggedIn() && request.auth.uid == resource.data.authorId;
      match /comments/{commentId} {
        allow read: if isLoggedIn();
        allow create: if isLoggedIn();
        allow delete: if isLoggedIn() && request.auth.uid == resource.data.authorId;
      }
    }

    // 채팅
    match /chats/{roomId}/messages/{msgId} {
      allow read, create: if isLoggedIn();
    }

    // 채팅방 목록
    match /rooms/{roomId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update, delete: if isLoggedIn() && request.auth.uid == resource.data.creatorId;
    }

    // 일정
    match /events/{eventId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update, delete: if isLoggedIn() && request.auth.uid == resource.data.creatorId;
    }

    // 미션: 본인만 읽기/쓰기, 관리자도 읽기 가능
    match /missions/{userId} {
      allow read: if isLoggedIn();
      allow write: if isOwner(userId);
      allow delete: if isLoggedIn(); // 관리자 삭제용
    }
  }
}
